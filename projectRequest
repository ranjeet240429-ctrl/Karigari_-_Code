{
  "name": "ProjectRequest",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Client full name"
    },
    "email": {
      "type": "string",
      "description": "Client email address"
    },
    "phone": {
      "type": "string",
      "description": "Client phone number"
    },
    "project_type": {
      "type": "string",
      "enum": [
        "business_website",
        "e_commerce",
        "landing_page",
        "web_application",
        "portfolio",
        "other"
      ],
      "description": "Type of project"
    },
    "description": {
      "type": "string",
      "description": "Detailed project description"
    },
    "budget": {
      "type": "string",
      "enum": [
        "under_10k",
        "10k_20k",
        "20k_35k",
        "35k_50k",
        "above_50k"
      ],
      "description": "Budget range"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "asap",
        "1_2_weeks",
        "2_4_weeks",
        "1_2_months",
        "flexible"
      ],
      "description": "Expected timeline"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "contacted",
        "in_progress",
        "completed"
      ],
      "default": "new",
      "description": "Request status"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "token_paid",
        "partially_paid",
        "fully_paid"
      ],
      "default": "pending",
      "description": "Payment status"
    }
  },
  "required": [
    "full_name",
    "email",
    "project_type",
    "description",
    "budget"
  ]
}